# --- Database ---
# Leave unset to use a local SQLite file (zero-setup demo mode).
# For PostgreSQL + pgvector:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/rfq_copilot
DATABASE_URL=

# --- LLM provider (optional — app runs fully in demo mode without it) ---
# GROQ_API_KEY=gsk_...
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Business rules ---
# GST rate applied when a quote says "GST extra" (cement = 28%, steel = 18%)
DEFAULT_GST_RATE=0.28
# Estimated freight per bag (INR) when quote is ex-godown / freight extra
FREIGHT_ESTIMATE_PER_BAG=10
FREIGHT_ESTIMATE_PER_TONNE=200

# --- CORS ---
FRONTEND_ORIGIN=http://localhost:3000